    "framer-motion": "^10.18.0",
    "next": "16.0.10",
    "next-themes": "^0.4.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "resend": "^6.12.2",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4.1.12",
    "@testing-library/dom": "^10.4.1",
