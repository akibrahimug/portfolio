    "postcss": "^8.5.3",
    "prettier": "^2.6.2",
    "tailwindcss": "^4.1.6",
    "tw-animate-css": "^1.2.9",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/akibrahimug/portfolio/client"
  },
  "bugs": {
