# Resend — contact form mailer.
# Sign up at https://resend.com (free tier: 3,000 emails/month).
# Create an API key, add it here.
RESEND_API_KEY=

# Where the contact form delivers messages.
RESEND_TO_EMAIL=kasomaibrahim@gmail.com

# From-address. Until a sender domain is verified in Resend, use the
# default `onboarding@resend.dev`. Once you verify a domain, switch to
# something like `noreply@kasomaibrahim.dev`.
RESEND_FROM_EMAIL=onboarding@resend.dev
